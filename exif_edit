    $hpaned->set_position($total - $exifpanelsize - 6);  # 6px für den Divider itselves
});

#################################################################################
# EXIF-Panel befüllen
#################################################################################
sub update_exif_panel {
    my ($filepath) = @_;
    $exif_store->clear;

    my $basename = basename($filepath);
    $exif_title->set_markup(
        '<span foreground="#cccccc" font="12" weight="bold">  EXIF: '
        . $basename . '</span>'
    );

    my $et = Image::ExifTool->new;
    $et->Options(DateFormat => '%Y-%m-%d %H:%M:%S',
                 Duplicates => 0,
                 RequestAll => 1,    # <-- NEU: fordert auch "versteckte" Tags wie Comment an
                 Group      => 0,    # <-- NEU: Schlüssel ohne Gruppen-Präfix (kein "File:Comment")
                );
    my $info = $et->ImageInfo($filepath, \@WANTED_TAGS);

    my %seen;
    for my $tag (@WANTED_TAGS) {
        next unless exists $info->{$tag};
        (my $bare = $tag) =~ s/.*://;
        next if $seen{$bare}++;
        my $val = $info->{$tag} // '';
        $val = '(binaer)' if ref $val;
        $val =~ s/[\x00-\x08\x0b\x0c\x0e-\x1f]//g;
        $exif_store->set($exif_store->append, 0, $bare, 1, "$val");
    }

    # Fallback: Tags mit Gruppenpräfix
    if (!$exif_store->iter_n_children(undef)) {
        my $info2 = $et->ImageInfo($filepath);
        for my $raw (sort keys %$info2) {
            (my $bare = $raw) =~ s/.*://;
            next unless $WANTED{$bare};
            next if $seen{$bare}++;
            my $val = $info2->{$raw} // '';
            $val = '(binaer)' if ref $val;
            $val =~ s/[\x00-\x08\x0b\x0c\x0e-\x1f]//g;
            $exif_store->set($exif_store->append, 0, $bare, 1, "$val");
        }
    }
}

#################################################################################
# Fokus setzen + EXIF-Panel aktualisieren
#################################################################################
sub set_focus_on {
    my ($focused, $filepath) = @_;
    foreach my $eb (@imageeventboxes) {
        $eb->get_style_context->remove_class('thumbnail-focused');
    }
    $focused->get_style_context->add_class('thumbnail-focused');
    update_exif_panel($filepath) if defined $filepath;
}

#################################################################################
# Todel
#################################################################################
sub todel_images {
    my @images = glob("*.JPG *.jpg *.png *.PNG *.jpeg *.JPEG");
    my $exifTool = Image::ExifTool->new();

    if (! -d 'todel') { `mkdir todel` }

    foreach my $file (@images) {
        my $comment = $exifTool->ImageInfo($file)->{"Comment"} // "";
        if ($comment eq 'todel') {
            `mv $file todel/`;
        }
    }
    &load_images;
}

#################################################################################
# Widgets entfernen
#################################################################################
sub remove_widget {
    my ($widget) = @_;
    $vbox_images->remove($widget);
}
$vbox_images->foreach(\&remove_widget);

#################################################################################
# Bilder laden
#################################################################################
sub load_images {
    $vbox_images->foreach(\&remove_widget);
    @imageeventboxes = ();

    # EXIF-Panel zurücksetzen
    $exif_store->clear;
    $exif_title->set_markup('<span foreground="#cccccc" font="12" weight="bold">  EXIF</span>');

    my @images = sort glob("*.JPG *.jpg *.png *.PNG *.jpeg *.JPEG");
    my $actfolder = `pwd`;
    $actfolder =~ s/\n//;
    my $num_picts = scalar @images;
    $window->set_title("exif_edit - $actfolder ($num_picts)");

    my $row;
    my $i = 0;

    foreach my $file (@images) {

        ## Thumbnail
        my $pixbuf = Gtk3::Gdk::Pixbuf->new_from_file_at_scale($file, $thumbsize, $thumbsize, TRUE);
        my $image  = Gtk3::Image->new_from_pixbuf($pixbuf);
        $image->get_style_context->add_class('thumbnail');

        my $imageeventbox = Gtk3::EventBox->new();
        $imageeventbox->add($image);
        $imageeventbox->add_events(['button-press-mask']);

        # Closure über $file für den EventBox-Handler
        my $captured_file = $file;
        $imageeventbox->signal_connect(button_press_event => sub {
            my ($widget, $event) = @_;
            if ($event->button == 1) {
                system("/bin/sh", "-c", "chromium \"$captured_file\" &");
            } elsif ($event->button == 3) {
                system("gimp \"$captured_file\" &");
            }
            # Fokus setzen UND EXIF-Panel aktualisieren
            set_focus_on($imageeventbox, $captured_file);
            return TRUE;
        });

        push(@imageeventboxes, $imageeventbox);

        ## EXIF Comment
        my $exifTool = Image::ExifTool->new;
        $exifTool->ExtractInfo($file);
        my $comment         = $exifTool->GetValue('Comment', 'PrintConv') // '';
        my $commententry    = Gtk3::Entry->new();
        my $comment_unicode = decode('UTF-8', $comment);
        $commententry->set_text($comment_unicode);
        $commententry->signal_connect(focus_out_event => sub {
            my $new_comment = $commententry->get_text();
            my $tool = Image::ExifTool->new;
            $tool->SetNewValue('Comment', $new_comment);
            $tool->WriteInfo($file);
            return FALSE;
        });

        ## Dateiname
        my $label         = Gtk3::Label->new($file);
        my $labeleventbox = Gtk3::EventBox->new();
        $labeleventbox->add($label);
        $labeleventbox->add_events(['button-press-mask']);
        $labeleventbox->signal_connect(button_press_event => sub {
            $commententry->set_text('todel');
            $exifTool->SetNewValue('Comment', 'todel');
            $exifTool->WriteInfo($file);
            return TRUE;
        });

        ## Container
        my $vbox = Gtk3::Box->new('vertical', 5);
        $vbox->pack_start($imageeventbox,  FALSE, FALSE, 0);
        $vbox->pack_start($labeleventbox,  FALSE, FALSE, 0);
        $vbox->pack_start($commententry,   FALSE, FALSE, 0);

        if ($i % $numofcolls == 0) {
            $row = Gtk3::Box->new('horizontal', 10);
            $vbox_images->pack_start($row, FALSE, FALSE, 10);
        }
        $i++;
        $row->pack_start($vbox, FALSE, FALSE, 10);
    }

    $vbox_images->show_all();
}

load_images();

$window->show_all();
Gtk3->main();

#################################################################################
## Hilfe-Fenster
#################################################################################
sub open_manual_window {
    my $top = Gtk3::Window->new('toplevel');
    $top->set_title("Manual");
    $top->set_default_size(400, 400);
    $top->set_position('center');

    my $manual_txt = <<'END_manual';
This program writes comments to images as an EXIF 'Comment' tag whenever a text field is exited.

* Clicking (with any mouse button) on the filename inserts the text 'todel' into the comment field.

* Left-clicking on a thumbnail opens the image in the Chromium browser.

* Right-clicking on a thumbnail opens the image in GIMP.

* The menu contains the 'Reload' option, which does exactly that.

* The 'To Del' option moves all images to a subdirectory named 'todel' (which is created if it doesn't already exist) and then reloads the thumbnails.

END_manual

    my $manual_txt_unicode = decode('UTF-8', $manual_txt);

    my $vbox = Gtk3::Box->new('vertical', 5);
    $vbox->set_border_width(10);
    $top->add($vbox);

    my $scrolled_win = Gtk3::ScrolledWindow->new;
    $scrolled_win->set_policy('automatic', 'automatic');
    my $textview = Gtk3::TextView->new;
    $textview->set_editable(0);
    $textview->set_cursor_visible(0);
    $textview->set_wrap_mode('word');
    $textview->get_buffer->set_text($manual_txt_unicode);
    $scrolled_win->add($textview);
    $vbox->pack_start($scrolled_win, TRUE, TRUE, 0);

    my $close_button = Gtk3::Button->new("Close");
    $close_button->signal_connect(clicked => sub { $top->destroy });
    $vbox->pack_start($close_button, FALSE, FALSE, 0);
    $top->show_all;
}

