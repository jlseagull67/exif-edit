#!/usr/bin/env perl
use strict;
use warnings;
use Gtk3 '-init';

#######################################################
# mit einem css-Style-Provider wird ein Rahmenobjekt
#  definiert, was in der Eventbox das Bild enthält
#######################################################

# Bildpfad (bitte anpassen)
my $file = '/home/joerg/Bilder/Apr2025/20250414_175507.JPG';

# CSS-Styles für Rahmen ein und aus
my $css_provider = Gtk3::CssProvider->new;
my $css_on = <<'END_CSS';
.frame-border {
    border: 2px solid lightgreen;
    padding: 5px;
}
END_CSS

my $css_off = <<'END_CSS';
.frame-border {
    border: none;
    padding: 5px;
}
END_CSS

# Wende CSS an
my $screen = Gtk3::Gdk::Screen::get_default;
$css_provider->load_from_data($css_on);
Gtk3::StyleContext::add_provider_for_screen($screen, $css_provider, Gtk3::STYLE_PROVIDER_PRIORITY_USER);


# Hauptfenster
my $window = Gtk3::Window->new('toplevel');
$window->set_title('Bild mit sichtbarem Rahmen');
$window->set_border_width(10);
$window->set_default_size(400, 300);
$window->signal_connect(delete_event => sub { Gtk3->main_quit });

# VBox
my $vbox = Gtk3::Box->new('vertical', 10);
$window->add($vbox);

# Frame-Ersatz: EventBox mit CSS-Klasse
my $eventbox = Gtk3::EventBox->new;
$eventbox->get_style_context->add_class('frame-border');

# Bild in den Rahmen
my $pixbuf = Gtk3::Gdk::Pixbuf->new_from_file_at_scale($file, 200, 200, 'TRUE');
my $image = Gtk3::Image->new_from_pixbuf($pixbuf);
$eventbox->add($image);

# Button
my $button = Gtk3::Button->new_with_label('Rahmen ein-/ausschalten');
my $rahmen_aktiv = 1;

$button->signal_connect(clicked => sub {
    if ($rahmen_aktiv) {
        $css_provider->load_from_data($css_off);
    } else {
        $css_provider->load_from_data($css_on);
    }
    $rahmen_aktiv = !$rahmen_aktiv;
});

# Hinzufügen zur VBox
$vbox->pack_start($eventbox, 1, 1, 0);
$vbox->pack_start($button, 0, 0, 0);

# Zeige alles
$window->show_all;
Gtk3->main;
