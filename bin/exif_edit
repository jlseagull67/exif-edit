#!/usr/bin/perl -w

use strict;
use warnings;
use utf8;
binmode STDOUT, ':utf8';
use Gtk3 -init;
use Glib 'TRUE', 'FALSE';
use File::Basename;
use Image::ExifTool;

#################################################################################
# CSS für Fokus-Anzeige
#################################################################################
# CSS für Rahmen ein/aus
my $css_provider = Gtk3::CssProvider->new;
my $css_styles = <<'END_CSS';
.thumbnail {
    padding: 5px 5px 5px 5px;
}
.thumbnail-focused {
    border: 1px solid lightgreen;
    border-radius: 5px;
    margin:  5px 5px 5px 5px;
}
END_CSS

# CSS laden
my $screen = Gtk3::Gdk::Screen::get_default;
$css_provider->load_from_data($css_styles);
Gtk3::StyleContext::add_provider_for_screen($screen, $css_provider, Gtk3::STYLE_PROVIDER_PRIORITY_USER);

# Sammler für alle Eventboxen (über den wird bei Fokusänderung iteriert)
my @imageeventboxes = ();


#################################################################################
# Window definition
#################################################################################
my $window = Gtk3::Window->new('toplevel');
# $window->set_title() see &load_images
$window->set_default_size(1600, 600);
$window->signal_connect(destroy => sub { Gtk3->main_quit });

my $monitor_width = Gtk3::Gdk::Display::get_default()
                  ->get_primary_monitor()
                  ->get_geometry()->{width};
my $thumbsize = $monitor_width > 1920 ? 400 : $monitor_width == 1920 ? 300 : $monitor_width == 1440 ? 200 : 150;
#$thumbsize = 150;

my $vbox_main = Gtk3::Box->new('vertical', 0);
$window->add($vbox_main);
$window->maximize();

#################################################################################
# Menue definition
#################################################################################
# Accelerator-Gruppe für Shortcuts
my $accel_group = Gtk3::AccelGroup->new();
$window->add_accel_group($accel_group);
my $menubar = Gtk3::MenuBar->new();

##################################
# Create Menue File
##################################
#   Datei
my $menu_item_datei = Gtk3::MenuItem->new_with_label("Datei");
my $menu_datei = Gtk3::Menu->new();
$menu_item_datei->set_submenu($menu_datei);

##################################
# Define Menue File
##################################
# Neu laden
my $menu_item_reload = Gtk3::MenuItem->new_with_label("Neu laden");
$menu_item_reload->signal_connect(activate => \&load_images);
$menu_item_reload->add_accelerator("activate", $accel_group, Gtk3::Gdk::KEY_r, ['control-mask'], 'visible');
$menu_datei->append($menu_item_reload);

# # ToDel
my $menu_item_todel = Gtk3::MenuItem->new_with_label("To Del");
$menu_item_todel->signal_connect(activate => \&todel_images);
$menu_item_todel->add_accelerator("activate", $accel_group, Gtk3::Gdk::KEY_d, ['control-mask'], 'visible');
$menu_datei->append($menu_item_todel);

# Beenden
my $menu_item_quit = Gtk3::MenuItem->new_with_label("Beenden");
$menu_item_quit->signal_connect(activate => sub { Gtk3->main_quit() });
$menu_item_quit->add_accelerator("activate", $accel_group, Gtk3::Gdk::KEY_q, ['control-mask'], 'visible');
$menu_datei->append($menu_item_quit);

# add to menuebar
$menubar->append($menu_item_datei);

##################################
# Create Menue ?
##################################
#   ?
my $menu_help = Gtk3::Menu->new();
my $menu_item_help = Gtk3::MenuItem->new_with_label("?");
$menu_item_help->set_submenu($menu_help);


##################################
# Menue Help
##################################
# Manual
my $menu_item_manual = Gtk3::MenuItem->new_with_label("Anleitung");
$menu_item_manual->signal_connect(activate => \&open_manual_window);
$menu_item_manual->add_accelerator("activate", $accel_group, Gtk3::Gdk::KEY_h, ['control-mask'], 'visible');
$menu_help->append($menu_item_manual);

##################################
# Menue Help
##################################
# Manual
my $menu_item_about = Gtk3::MenuItem->new_with_label("Über das Programm");
$menu_item_about->signal_connect(activate => \&open_about_window);
#$menu_item_manual->add_accelerator("activate", $accel_group, Gtk3::Gdk::KEY_h, ['control-mask'], 'visible');
$menu_help->append($menu_item_about);

# add to menuebar
$menubar->append($menu_item_help);


$vbox_main->pack_start($menubar, FALSE, FALSE, 0);

#################################################################################
# Scrollbereich im Fenster
#################################################################################
my $scroll = Gtk3::ScrolledWindow->new();
$scroll->set_policy('automatic', 'automatic');
$vbox_main->pack_start($scroll, TRUE, TRUE, 0);

# Bildcontainer
my $vbox_images = Gtk3::Box->new('vertical', 10);
$scroll->add($vbox_images);

#################################################################################
# Todel-Funktion
# Verschiebt alle Bilder mit Exif-Comment = todel in ein Unterverzeichnis
#################################################################################
sub todel_images {
    my @images = glob("*.JPG *.jpg *.png *.PNG *.jpeg *.JPEG");
    my $exifTool = Image::ExifTool->new();
    my $col = 0;
    my $row = 0;

    if (! -d 'todel'){
        `mkdir todel`;
    }
    my $comment ='';

    foreach my $file (@images) {

        $comment = $exifTool->ImageInfo($file)->{"Comment"} // "";

        if ($comment eq 'todel') {
            `mv $file todel/`;
        }
    }
    &load_images;
}

#################################################################################
# Lösche alle Widgets
#################################################################################
sub remove_widget {
    my ($widget) = @_;
    $vbox_images->remove($widget);
}
$vbox_images->foreach(\&remove_widget);  # Clear

#################################################################################
# Setzt den Fokus auf einen Container
#################################################################################
sub set_focus_on {
    my ($focused) = @_;
    foreach my $imageeventbox (@imageeventboxes) {
        my $ctx = $imageeventbox->get_style_context;
        $ctx->remove_class('thumbnail-focused');
    }
    $focused->get_style_context->add_class('thumbnail-focused');
}

#################################################################################
# Function to load objects for to display Image, Label, Comment
#################################################################################
sub load_images {
    $vbox_images->foreach(\&remove_widget);  # Clear

    @imageeventboxes = ();

    my @images = glob("*.JPG *.jpg *.png *.PNG *.jpeg *.JPEG");
    @images = sort @images;
    my $actfolder = `pwd`;
    $actfolder =~ s/\n//;
    my $num_picts = @images;
    $window->set_title("exif_edit - $actfolder ($num_picts)");
    my $row;
    my $col;
    my $i = 0;

    foreach my $file (@images) {

        #######################
        ## Image
        my $pixbuf = Gtk3::Gdk::Pixbuf->new_from_file_at_scale($file, $thumbsize, $thumbsize, TRUE);
        my $image = Gtk3::Image->new_from_pixbuf($pixbuf);

        # CSS-Style for image (not for $imageeventbox !)
        $image->get_style_context->add_class('thumbnail');

        # Pack image into an EventBox to allow mouse interaction
        my $imageeventbox = Gtk3::EventBox->new();
        $imageeventbox->add($image);
        $imageeventbox->add_events(['button-press-mask']);
        $imageeventbox->signal_connect(button_press_event => sub {
            my ($widget, $event) = @_;
            if ($event->button == 1) {
                system("firefox \"$file\" &");
            } elsif ($event->button == 3) {
                system("gimp \"$file\" &");
            }
            set_focus_on($imageeventbox);
            return TRUE;
        });
        # Collect all eventboxes (for focus management)
        push (@imageeventboxes, $imageeventbox);

        #######################
        ## EXIF "Comment"
        my $exifTool = Image::ExifTool->new;
        $exifTool->ExtractInfo($file);
        my $comment = $exifTool->GetValue('Comment', 'PrintConv') // '';
        my $commententry = Gtk3::Entry->new();
        $commententry->set_text($comment);
        $commententry->signal_connect(focus_out_event => sub {
            my $new_comment = $commententry->get_text();
            my $tool = Image::ExifTool->new;
            $tool->SetNewValue('Comment', $new_comment);
            $tool->WriteInfo($file);
            return FALSE;
        });

        #######################
        ## File Name Label
        my $label = Gtk3::Label->new($file);
        # signal-handler for click on file label
        my $labeleventbox = Gtk3::EventBox->new();
        $labeleventbox->add($label);
        $labeleventbox->add_events(['button-press-mask']);
        $labeleventbox->signal_connect(button_press_event => sub {
            print "gotcha \n";
            $commententry->set_text('todel');
            $exifTool->SetNewValue('Comment', 'todel');
            $exifTool->WriteInfo($file);
            return TRUE;
        });


        # Container für Bild, Label, Entry
        my $vbox = Gtk3::Box->new('vertical', 5);
        $vbox->pack_start($imageeventbox, FALSE, FALSE, 0);
        $vbox->pack_start($labeleventbox, FALSE, FALSE, 0);
        $vbox->pack_start($commententry, FALSE, FALSE, 0);

        # Neue Zeile alle 6 Bilder
        if ($i % 6 == 0) {
            $row = Gtk3::Box->new('horizontal', 10);
            $vbox_images->pack_start($row, FALSE, FALSE, 10);
        }
        $i ++;
        $row->pack_start($vbox, FALSE, FALSE, 10);
    }

    $vbox_images->show_all();
}

$menu_item_reload->signal_connect(activate => \&load_images);
$menu_item_todel->signal_connect(activate => \&todel_images);
$menu_item_quit->signal_connect(activate => sub { Gtk3->main_quit });

load_images();


$window->show_all();
Gtk3->main();

#################################################################################
## Hilfefenster - Anleitung
#################################################################################
sub open_manual_window {
    my $top = Gtk3::Window->new('toplevel');
    $top->set_title("Textfenster");
    $top->set_default_size(400, 300);
    $top->set_position('center');


    my $manual_txt = <<'END_manual';
* Dieses Programm schreibt Kommentare zu Bildern als EXIF-Tag "Comment", wenn immer das ein Textfeld verlassen wird.

* Ein Klick (egal mit welcher Mouse-Taste) auf den Dateinamen setzt als den Text "todel" in das Kommentarfeld.
* Ein Links-Klick auf ein Thumbnail öffnet das Bild im Firefox.
* Ein Rechtsklick auf ein Thumbnail öffnet das Bild im Gimp.
* Das Menue enthält den Eintrag "Neu Laden" und macht genau das.
* Der Eintrag "To Del" verschiebt alle Bilder in ein Unterverzeichnis 'todel', welches angelegt wird, wenn es nicht schon existiert und lädt anschließend die Thumbnails neu.

END_manual

    my $vbox = Gtk3::Box->new('vertical', 5);
    $vbox->set_border_width(10);
    $top->add($vbox);

    # Scrollbares Textfeld
    my $scrolled_win = Gtk3::ScrolledWindow->new;
    $scrolled_win->set_policy('automatic', 'automatic');

    my $textview = Gtk3::TextView->new;
    $textview->set_editable(0);      # Nicht editierbar
    $textview->set_cursor_visible(0);# Cursor nicht anzeigen
    $textview->set_wrap_mode('word');# Text umbrechen

    # Text setzen
    my $buffer = $textview->get_buffer;
    $buffer->set_text($manual_txt);

    $scrolled_win->add($textview);
    $vbox->pack_start($scrolled_win, TRUE, TRUE, 0);

    # Schließen-Button
    my $close_button = Gtk3::Button->new("Schließen");
    $close_button->signal_connect(clicked => sub { $top->destroy });
    $vbox->pack_start($close_button, FALSE, FALSE, 0);

    $top->show_all;
}

#################################################################################
## About Fenster
#################################################################################
sub open_about_window {
    my $top = Gtk3::Window->new('toplevel');
    $top->set_title("Textfenster");
    $top->set_default_size(400, 300);
    $top->set_position('center');


    my $about_txt = <<'END_about';
* Dieses Programm schreibt Kommentare zu Bildern als EXIF-Tag "Comment".

Ich übernehme für das Programm keine Garantie. Es kann frei geändert oder weitergegeben werden unter den selben Bedingungen wie Perl selbst.

Wenn dir das Programm gefällt freue ich mich über eine Spende.

 Jörg Albrecht
 IBAN DE93 5001 0517 5436 0360 49

END_about

    my $vbox = Gtk3::Box->new('vertical', 5);
    $vbox->set_border_width(10);
    $top->add($vbox);

    # Scrollbares Textfeld
    my $scrolled_win = Gtk3::ScrolledWindow->new;
    $scrolled_win->set_policy('automatic', 'automatic');

    my $textview = Gtk3::TextView->new;
    $textview->set_editable(0);      # Nicht editierbar
    $textview->set_cursor_visible(0);# Cursor nicht anzeigen
    $textview->set_wrap_mode('word');# Text umbrechen

    # Text setzen
    my $buffer = $textview->get_buffer;
    $buffer->set_text($about_txt);

    $scrolled_win->add($textview);
    $vbox->pack_start($scrolled_win, TRUE, TRUE, 0);

    # Schließen-Button
    my $close_button = Gtk3::Button->new("Schließen");
    $close_button->signal_connect(clicked => sub { $top->destroy });
    $vbox->pack_start($close_button, FALSE, FALSE, 0);

    $top->show_all;
}
