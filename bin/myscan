#!/usr/bin/perl
use strict;
use warnings;
use Gtk3 -init;
use Glib qw(TRUE FALSE);
#use Image::Magick;
use File::Temp qw(tempfile);
use Cairo;


#################################################################################
# Main Window definition
#################################################################################
my $window = Gtk3::Window->new('toplevel');
$window->set_title('Epson DS-6500 Scan Tool');
$window->set_default_size(900, 600);
$window->signal_connect(delete_event => sub { Gtk3->main_quit });

#$window->maximize();  # full screen window
my $monitor_width = Gtk3::Gdk::Display::get_default()
                  ->get_primary_monitor()
                  ->get_geometry()->{width};
my $monitor_height = Gtk3::Gdk::Display::get_default()
                  ->get_primary_monitor()
                  ->get_geometry()->{height};
print "$monitor_width / $monitor_height\n";

#################################################################################
# Main-HBox erstellen
#################################################################################
my $mainbox = Gtk3::Box->new('horizontal', 5);
$mainbox->set_homogeneous(0);  # boxes may be different in size
$window->add($mainbox);


#################################################################################
# drawing area definition
#################################################################################
my $drawbox = Gtk3::Box->new('vertical', 5);
$mainbox->add($drawbox);

# Variables
my ($pixbuf, $surface, $start_x, $start_y, $end_x, $end_y, $selecting);

# Bild laden
$pixbuf = Gtk3::Gdk::Pixbuf->new_from_file('deinbild.png');
$surface = create_surface_from_pixbuf($pixbuf);

my $drawing_area = Gtk3::DrawingArea->new;
$drawing_area->set_size_request(1000, 1300);
$drawbox->add($drawing_area);

# Zeichen-Callback
$drawing_area->signal_connect(draw => sub {
    my ($widget, $cr) = @_;

    # Bild zeichnen
    $cr->set_source_surface($surface, 0, 0);
    $cr->paint;

    ## dummy-Rechteck zeichnen
    #$start_x = 100;
    #$start_y = 100;
    #$end_x = 200;
    #$end_y = 200;


    # Rechteck zeichnen, falls vorhanden
    if (defined $start_x && defined $start_y && defined $end_x && defined $end_y) {
        my $x = $start_x;
        my $y = $start_y;
        my $w = $end_x - $start_x;
        my $h = $end_y - $start_y;

        # Korrigieren bei negativen Werten
        if ($w < 0) {
            $x += $w;
            $w = -$w;
        }
        if ($h < 0) {
            $y += $h;
            $h = -$h;
        }

        # selection filling
        $cr->set_source_rgba(0, 0, 0, 0); # r, g, b, transparency
        $cr->rectangle($x, $y, $w, $h);
        $cr->fill_preserve;

        # selection line
        $cr->set_source_rgb(1, 0, 0); # red line
        $cr->set_line_width(0.5);
        $cr->stroke;

        # coordinates
        #my $text = "${w}×${h}px";
        my $x_coord = int(${w});
        my $y_coord = int(${h});
        my $text = "$x_coord x $y_coord px";

        $cr->select_font_face('Sans', 'normal', 'normal');
        $cr->set_font_size(10);
        $cr->set_source_rgb(1, 0, 0);  # red text
        $cr->move_to($x + 5, $y - 5 > 0 ? $y - 5 : $y + 20);
        $cr->show_text($text);
    }
    return FALSE;
});

################################
# Mouse Events for selection
################################
$drawing_area->add_events(['button-press-mask', 'button-release-mask', 'pointer-motion-mask']);

$drawing_area->signal_connect(button_press_event => sub {
    my ($widget, $event) = @_;
    $selecting = 1;
    $start_x = $end_x = $event->x;
    $start_y = $end_y = $event->y;
    $drawing_area->queue_draw;
    return TRUE;
});

$drawing_area->signal_connect(motion_notify_event => sub {
    my ($widget, $event) = @_;
    if ($selecting) {
        $end_x = $event->x;
        $end_y = $event->y;
        $drawing_area->queue_draw;
    }
    return TRUE;
});

$drawing_area->signal_connect(button_release_event => sub {
    my ($widget, $event) = @_;
    $selecting = 0;
    $drawing_area->queue_draw;
    return TRUE;
});

#################################################################################
# box separator
#################################################################################
my $separator = Gtk3::Separator->new('vertical');
$mainbox->add($separator);

#################################################################################
# action box definition
#################################################################################
my $settingsbox = Gtk3::Box->new('vertical', 10);
$mainbox->add($settingsbox);

#$mainbox->pack_start($settingsbox, FALSE, FALSE, 10);

my $color_combo = Gtk3::ComboBoxText->new;
$color_combo->append_text($_) for qw(lineart Gray Color);
$color_combo->set_active(2);
$settingsbox->pack_start(Gtk3::Label->new('Farbmodus:'), FALSE, FALSE, 0);
$settingsbox->pack_start($color_combo, FALSE, FALSE, 0);

my $res_combo = Gtk3::ComboBoxText->new;
$res_combo->append_text($_) for qw(100 200 300 spezial);
$res_combo->set_active(1);
$settingsbox->pack_start(Gtk3::Label->new('Auflösung:'), FALSE, FALSE, 0);
$settingsbox->pack_start($res_combo, FALSE, FALSE, 0);

my $scan_radio = Gtk3::RadioButton->new_with_label(undef, 'Scannen');
my $copy_radio = Gtk3::RadioButton->new_with_label($scan_radio, 'Kopieren');
$settingsbox->pack_start($scan_radio, FALSE, FALSE, 0);
$settingsbox->pack_start($copy_radio, FALSE, FALSE, 0);

my $source_combo = Gtk3::ComboBoxText->new;
$source_combo->append_text($_) for qw(Flatbed ADF 'ADF Duplex');
$source_combo->set_active(0);
$settingsbox->pack_start(Gtk3::Label->new('Quelle:'), FALSE, FALSE, 0);
$settingsbox->pack_start($source_combo, FALSE, FALSE, 0);

# Scan Button
my $scan_btn = Gtk3::Button->new_with_label('Scan starten');
$settingsbox->pack_start($scan_btn, FALSE, FALSE, 10);

$scan_btn->signal_connect(clicked => sub {
    my $mode = $color_combo->get_active_text;
    my $res = $res_combo->get_active_text eq 'spezial' ? 150 : $res_combo->get_active_text;
    my $source = $source_combo->get_active_text;

    # build the command

    # These are the commands, that our scanner accepts:
    #scanimage -d epsonscan2:networkscanner:esci2:network:192.168.167.20 --all-option

    my ($fh, $filename) = tempfile(SUFFIX => '.pnm', UNLINK => 0);

    open(my $out, '>', $filename) or die "Kann Datei nicht öffnen: $!";
     # funktioniert in der Shell:  scanimage -d epsonscan2:networkscanner:esci2:network:192.168.167.20 > testimg
    my $pid = open(my $scan, '-|', 'scanimage -d epsonscan2:networkscanner:esci2:network:192.168.167.20'.
        ' --format=pnm'.
        ' --resolution '. $res.
        ' --mode '. $mode.
        ' --source '. $source
    ) or die "Scan fehlgeschlagen: $!";
    while (read($scan, my $buffer, 4096)) {
        print $out $buffer;
    }
    close $scan;
    close $out;

    # Bild laden
    $pixbuf = Gtk3::Gdk::Pixbuf->new_from_file($filename);
    $surface = create_surface_from_pixbuf($pixbuf);

#    $image_full = Image::Magick->new;
#    $image_full->Read($filename);

    $pixbuf = Gtk3::Gdk::Pixbuf->new_from_file_at_size($filename, 500, 600);
    $drawing_area->queue_draw;
});


my $save_btn = Gtk3::Button->new_with_label('Ausschnitt speichern');
$settingsbox->pack_start($save_btn, FALSE, FALSE, 10);

$save_btn->signal_connect(clicked => sub {
    save_selection()
});


#################################################################################
# show all and main loop
#################################################################################
$window->show_all;
Gtk3->main;

# ========================
# Hilfsfunktionen
# ========================

sub create_surface_from_pixbuf {
    my ($pixbuf) = @_;
    my $w = $pixbuf->get_width;
    my $h = $pixbuf->get_height;

    # Erstelle eine Cairo-ImageSurface
    my $surface = Cairo::ImageSurface->create('argb32', $w, $h);
    my $cr = Cairo::Context->create($surface);

    # Zeichne Pixbuf auf Surface
    my $pixels = $pixbuf->get_pixels;
    my $rowstride = $pixbuf->get_rowstride;
    my $n_channels = $pixbuf->get_n_channels;

    for my $y (0 .. $h - 1) {
        for my $x (0 .. $w - 1) {
            my $p = substr($pixels, $y * $rowstride + $x * $n_channels, $n_channels);
            my ($r, $g, $b, $a) = map { ord($_) / 255 } split(//, $p);
            $a = 1 unless defined $a;  # PNGs ohne Alpha

            $cr->set_source_rgba($r, $g, $b, $a);
            $cr->rectangle($x, $y, 1, 1);
            $cr->fill;
        }
    }
    return $surface;
}


sub save_selection {

    print "gotcha in save_selection\n";

    my $x = int($start_x < $end_x ? $start_x : $end_x);
    my $y = int($start_y < $end_y ? $start_y : $end_y);
    my $w = abs($end_x - $start_x);
    my $h = abs($end_y - $start_y);

    return if ($w <= 0 || $h <= 0);

    my $subpixbuf = $pixbuf->new_subpixbuf($x, $y, $w, $h);

    my $dialog = Gtk3::FileChooserDialog->new(
        'Speichern unter', $window,
        'save',
        'gtk-cancel' => 'cancel',
        'gtk-save'   => 'accept',
    );

    if ($dialog->run eq 'accept') {
        my $filename = $dialog->get_filename;
        $subpixbuf->save($filename, 'png');
    }
    $dialog->destroy;
}
