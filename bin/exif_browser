#!/usr/bin/env perl
#
# exif_browser  -  GTK3-Program for search an show EXIF-Daten
#                   and to show foto thumbnails
#
# usage:
#   perl exif_browser [--db <file>]
#

use strict;
use warnings;
use utf8;

use Gtk3 '-init';
use Glib qw(TRUE FALSE);
use Glib::Object::Introspection;
use DBI;
use File::Basename qw(basename dirname);
use POSIX qw(floor);
use Getopt::Long qw(GetOptions);
use Scalar::Util qw(looks_like_number);

# Diagnostic log (runs after Gtk3 init)
open my $LOG, '>>', '/tmp/exif_browser.log' or die "Cannot open log: $!";
$LOG->autoflush(1);
sub log_msg { print $LOG scalar(localtime) . "  $_[0]\n" }
log_msg("=== exif_browser starting ===");
log_msg("Perl: $]  PID: $$");

binmode STDOUT, ':utf8';
binmode STDERR, ':utf8';
log_msg('binmode OK');

# GdkPixbuf via Introspection laden
Glib::Object::Introspection->setup(
    basename => 'GdkPixbuf',
    version  => '2.0',
    package  => 'GdkPixbuf',
);
log_msg('GdkPixbuf introspection OK');

# ─── Konfiguration ────────────────────────────────────────────────────────────
my $DB_FILE      = 'exif_data.db';
my $THUMB_SIZE   = 160;
my $APP_TITLE    = 'EXIF Photo Browser';
my $APP_VERSION  = '1.0';

GetOptions('db=s' => $DB_FILE) or die "ERROR: in arguments\n";
log_msg("DB file: $DB_FILE  exists=" . (-f $DB_FILE ? 'yes' : 'NO'));

unless (-f $DB_FILE) {
    show_startup_error(
        "Database not found: $DB_FILE\n\n" .
        "Please run exif2sqlite first:\n" .
        "  perl exif2sqlite --db $DB_FILE /pfad/zu/fotos"
    );
    exit 1;
}
log_msg("DB connected OK");

# ─── Globaler Zustand ─────────────────────────────────────────────────────────
my $dbh;
my @current_results   = ();   # current search result rows
my $current_offset    = 0;    # index of first shown thumbnail
my $PAGE_SIZE         = 100;  # thumbnails per page
my $selected_photo_id = undef;
my $thumb_size        = $THUMB_SIZE;
my %thumb_cache       = ();   # photo_id => GdkPixbuf
my %widget_data       = ();   # widget_ref => { photo_id, photo_path }
my $search_idle_id    = undef;

# ─── Path prefix mapping (for photos indexed on a different machine) ──────────
my $path_prefix_from  = '';   # prefix in DB  (e.g. /mnt/nas/photos)
my $path_prefix_to    = '';   # local prefix  (e.g. /home/user/photos)
my $CONFIG_FILE         = "$ENV{HOME}/.config/exif_browser.conf";
my $EXIF_SELECTOR_CONF  = "$ENV{HOME}/.config/exif_selector/config.yaml";
my %selected_tags       = ();   # tags from exif_selector config (empty = show all)

# ─── Database connection ──────────────────────────────────────────────────────
eval {
    $dbh = DBI->connect(
        "dbi:SQLite:dbname=$DB_FILE",
        '', '',
        { RaiseError => 1, AutoCommit => 1, sqlite_unicode => 1, PrintError => 0 }
    );
    $dbh->do("PRAGMA journal_mode = WAL");
    $dbh->do("PRAGMA cache_size   = 5000");
};
if ($@) {
    show_startup_error("Database error: $@");
    exit 1;
}

# ─── CSS-Styling ──────────────────────────────────────────────────────────────
my $css = Gtk3::CssProvider->new;
$css->load_from_data(<<'CSS');
/* Hauptfenster */
window {
    background-color: #1e1e2e;
}

/* Header / Suchleiste */
.search-bar {
    background-color: #2a2a3e;
    border-bottom: 1px solid #44475a;
    padding: 8px;
}

.search-label {
    color: #cdd6f4;
    font-weight: bold;
    font-size: 11px;
}

/* Tag-Auswahl ComboBox */
.tag-combo {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #44475a;
    border-radius: 4px;
}

/* Suchfeld */
.search-entry {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #44475a;
    border-radius: 4px;
    caret-color: #cba6f7;
}
.search-entry:focus {
    border-color: #cba6f7;
    box-shadow: 0 0 0 2px rgba(203,166,247,0.3);
}

/* Thumbnail-Bereich */
.thumb-scroll {
    background-color: #181825;
}

.thumb-flowbox {
    background-color: #181825;
    padding: 12px;
}

/* Einzelnes Thumbnail-Widget */
.thumb-frame {
    background-color: #2a2a3e;
    border: 2px solid transparent;
    border-radius: 8px;
    padding: 6px;
    margin: 4px;
    transition: border-color 200ms;
}
.thumb-frame:hover {
    border-color: #6c7086;
    background-color: #313244;
}
.thumb-frame.selected {
    border-color: #cba6f7;
    background-color: #313244;
}

.thumb-label {
    color: #a6adc8;
    font-size: 10px;
    margin-top: 4px;
}

/* Detail-Panel */
.detail-panel {
    background-color: #2a2a3e;
    border-left: 1px solid #44475a;
}

.detail-header {
    background-color: #313244;
    border-bottom: 1px solid #44475a;
    padding: 10px;
}

.detail-title {
    color: #cdd6f4;
    font-weight: bold;
    font-size: 12px;
}

.detail-path {
    color: #7f849c;
    font-size: 10px;
}

/* Tag-Liste im Detail */
.tag-tree {
    background-color: #2a2a3e;
    color: #cdd6f4;
    font-size: 11px;
}

/* Statusleiste */
.statusbar {
    background-color: #2a2a3e;
    border-top: 1px solid #44475a;
    padding: 2px 8px;
    font-size: 10px;
    color: #7f849c;
}

/* Such-Buttons */
button.search-btn {
    background-color: #cba6f7;
    color: #1e1e2e;
    border: none;
    border-radius: 4px;
    font-weight: bold;
    padding: 4px 12px;
}
button.search-btn:hover {
    background-color: #d0b0ff;
}

button.reset-btn {
    background-color: #45475a;
    color: #cdd6f4;
    border: none;
    border-radius: 4px;
    padding: 4px 12px;
}
button.reset-btn:hover {
    background-color: #585b70;
}

/* Slider-Beschriftung */
.slider-label {
    color: #7f849c;
    font-size: 10px;
}

/* Trennlinie */
separator {
    background-color: #44475a;
    min-height: 1px;
}

/* Keine Ergebnisse */
.empty-label {
    color: #45475a;
    font-size: 16px;
    font-weight: bold;
    margin: 40px;
}

/* Großbild-Viewer */
.viewer-bg {
    background-color: #11111b;
}

/* FlowBoxChild Hintergrund transparent */
flowboxchild {
    background-color: transparent;
    padding: 0;
    margin: 0;
}
flowboxchild:selected {
    background-color: transparent;
}
CSS
log_msg("CSS loaded OK");

my $screen   = Gtk3::Gdk::Screen::get_default();
my $priority = Gtk3::STYLE_PROVIDER_PRIORITY_APPLICATION();
log_msg("adding CSS provider to screen...");
Gtk3::StyleContext::add_provider_for_screen($screen, $css, $priority);
log_msg('CSS provider added to screen');

# ─── Main window ─────────────────────────────────────────────────────────────
log_msg('Creating main window');
my $window = Gtk3::Window->new('toplevel');
$window->set_title($APP_TITLE);
$window->set_default_size(1280, 780);
$window->set_position('center');
$window->signal_connect(destroy => sub { $dbh->disconnect if $dbh; Gtk3->main_quit });
log_msg('Window configured OK');

# ─── Main Layout: Vertikal (Suchleiste + Inhalt + Statusleiste) ──────────────
my $vbox_main = Gtk3::Box->new('vertical', 0);
$window->add($vbox_main);

# ── Search frame ────────────────────────────────────────────────────────────────
my $search_bar = Gtk3::Box->new('horizontal', 8);
$search_bar->get_style_context->add_class('search-bar');
$search_bar->set_border_width(8);
$vbox_main->pack_start($search_bar, FALSE, FALSE, 0);

# App-Title
my $title_label = Gtk3::Label->new("$APP_TITLE");
$title_label->get_style_context->add_class('detail-title');
$search_bar->pack_start($title_label, FALSE, FALSE, 4);

my $sep1 = Gtk3::Separator->new('vertical');
$search_bar->pack_start($sep1, FALSE, FALSE, 4);

my $btn_remap = Gtk3::Button->new_with_label("Paths ...");
$btn_remap->get_style_context->add_class('reset-btn');
$btn_remap->set_tooltip_text("Configure photo path mapping");
$search_bar->pack_start($btn_remap, FALSE, FALSE, 0);

# Label: Tag
my $lbl_tag = Gtk3::Label->new("EXIF Tag:");
$lbl_tag->get_style_context->add_class('search-label');
$search_bar->pack_start($lbl_tag, FALSE, FALSE, 0);

# Plain text entry for tag name
my $combo_tag = Gtk3::Entry->new;
$combo_tag->get_style_context->add_class('search-entry');
$combo_tag->set_size_request(220, -1);
$combo_tag->set_tooltip_text("EXIF tag to search (e.g. Comment, Model, Make)");
$combo_tag->set_text("Comment");
$search_bar->pack_start($combo_tag, FALSE, FALSE, 0);

# Label: Value
my $lbl_val = Gtk3::Label->new("Value (contains):");
$lbl_val->get_style_context->add_class('search-label');
$search_bar->pack_start($lbl_val, FALSE, FALSE, 4);

# Suchfeld für Wert
my $entry_value = Gtk3::SearchEntry->new;
log_msg("entry_value OK");
$entry_value->get_style_context->add_class('search-entry');
$entry_value->set_size_request(260, -1);
$entry_value->set_placeholder_text("e.g. Canon, 2024, iPhone ...");
$search_bar->pack_start($entry_value, FALSE, FALSE, 0);

# Such-Button
my $btn_search = Gtk3::Button->new_with_label("  Search  ");
log_msg("btn_search OK");
$btn_search->get_style_context->add_class('search-btn');
$search_bar->pack_start($btn_search, FALSE, FALSE, 0);

# Reset-Button
my $btn_reset = Gtk3::Button->new_with_label("Show All");
$btn_reset->get_style_context->add_class('reset-btn');
$search_bar->pack_start($btn_reset, FALSE, FALSE, 0);

# Spacer
$search_bar->pack_start(Gtk3::Box->new('horizontal',0), TRUE, TRUE, 0);

# Slider for thumbnail size
my $lbl_size = Gtk3::Label->new("Size:");
$lbl_size->get_style_context->add_class('slider-label');
$search_bar->pack_start($lbl_size, FALSE, FALSE, 0);

my $size_adj = Gtk3::Adjustment->new($thumb_size, 80, 300, 10, 20, 0);
log_msg("size_adj OK");
my $slider   = Gtk3::Scale->new('horizontal', $size_adj);
$slider->set_draw_value(FALSE);
$slider->set_size_request(120, -1);
$slider->set_tooltip_text("Adjust thumbnail size");
$search_bar->pack_start($slider, FALSE, FALSE, 0);

my $lbl_size_val = Gtk3::Label->new("${thumb_size}px");
$lbl_size_val->get_style_context->add_class('slider-label');
$lbl_size_val->set_width_chars(5);
$search_bar->pack_start($lbl_size_val, FALSE, FALSE, 0);

# ── Haupt-Inhaltsbereich: Horizontal (Thumbnails + Detail-Panel) ──────────────
log_msg("search bar complete, building paned");
my $paned = Gtk3::Paned->new('horizontal');
$paned->set_position(870);
$vbox_main->pack_start($paned, TRUE, TRUE, 0);

# ── left frame: Thumbnail-Gitter ─────────────────────────────────────────────
my $left_box = Gtk3::Box->new('vertical', 0);
$paned->pack1($left_box, TRUE, FALSE);

# Result Info Bar
my $result_bar = Gtk3::Box->new('horizontal', 8);
$result_bar->get_style_context->add_class('search-bar');
$result_bar->set_border_width(4);
$left_box->pack_start($result_bar, FALSE, FALSE, 0);

my $lbl_results = Gtk3::Label->new("Select an EXIF tag and value to search");
log_msg("lbl_results OK");
$lbl_results->get_style_context->add_class('search-label');
$lbl_results->set_xalign(0.0);
$result_bar->pack_start($lbl_results, TRUE, TRUE, 4);

my $btn_first = Gtk3::Button->new_with_label("<<");
$btn_first->get_style_context->add_class('reset-btn');
$btn_first->set_sensitive(FALSE);
$result_bar->pack_start($btn_first, FALSE, FALSE, 0);

my $btn_prev = Gtk3::Button->new_with_label("< Prev");
$btn_prev->get_style_context->add_class('reset-btn');
$btn_prev->set_sensitive(FALSE);
$result_bar->pack_start($btn_prev, FALSE, FALSE, 0);

my $lbl_page = Gtk3::Label->new("");
$lbl_page->get_style_context->add_class('search-label');
$lbl_page->set_width_chars(12);
$lbl_page->set_xalign(0.5);
$result_bar->pack_start($lbl_page, FALSE, FALSE, 0);

my $btn_next = Gtk3::Button->new_with_label("Next >");
$btn_next->get_style_context->add_class('reset-btn');
$btn_next->set_sensitive(FALSE);
$result_bar->pack_start($btn_next, FALSE, FALSE, 0);

my $btn_last = Gtk3::Button->new_with_label(">>");
$btn_last->get_style_context->add_class('reset-btn');
$btn_last->set_sensitive(FALSE);
$result_bar->pack_start($btn_last, FALSE, FALSE, 0);

# Spinner replaced by modal busy dialog (see show_busy / hide_busy subs)

# Scrollbar FlowBox
my $scroll = Gtk3::ScrolledWindow->new;
log_msg("scroll OK");
$scroll->get_style_context->add_class('thumb-scroll');
$scroll->set_policy('automatic', 'automatic');
$scroll->set_shadow_type('none');
$left_box->pack_start($scroll, TRUE, TRUE, 0);

# Viewport + FlowBox
my $flowbox = Gtk3::FlowBox->new;
log_msg("flowbox OK");
$flowbox->get_style_context->add_class('thumb-flowbox');
$flowbox->set_homogeneous(TRUE);
$flowbox->set_row_spacing(8);
$flowbox->set_column_spacing(8);
$flowbox->set_selection_mode('single');
$flowbox->set_max_children_per_line(20);
$scroll->add($flowbox);
log_msg('FlowBox and scroll OK');

# ── right Frame: detail panel ────────────────────────────────────────────────
my $detail_box = Gtk3::Box->new('vertical', 0);
$detail_box->get_style_context->add_class('detail-panel');
$detail_box->set_size_request(380, -1);
$paned->pack2($detail_box, FALSE, FALSE);

# Detail-Header
my $detail_header = Gtk3::Box->new('vertical', 2);
$detail_header->get_style_context->add_class('detail-header');
$detail_header->set_border_width(10);
$detail_box->pack_start($detail_header, FALSE, FALSE, 0);

my $lbl_detail_title = Gtk3::Label->new("No photo selected");
$lbl_detail_title->get_style_context->add_class('detail-title');
$lbl_detail_title->set_xalign(0.0);
$lbl_detail_title->set_ellipsize('middle');
$detail_header->pack_start($lbl_detail_title, FALSE, FALSE, 0);

my $lbl_detail_path = Gtk3::Label->new("");
$lbl_detail_path->get_style_context->add_class('detail-path');
$lbl_detail_path->set_xalign(0.0);
$lbl_detail_path->set_ellipsize('start');
$lbl_detail_path->set_tooltip_text("");
$detail_header->pack_start($lbl_detail_path, FALSE, FALSE, 0);

# Großes Vorschaubild im Detail
my $detail_image_frame = Gtk3::AspectFrame->new(undef, 0.5, 0.5, 1.0, FALSE);
$detail_image_frame->set_shadow_type('none');
$detail_image_frame->set_border_width(8);
my $detail_image = Gtk3::Image->new;
$detail_image->set_size_request(-1, 200);
$detail_image_frame->add($detail_image);
$detail_box->pack_start($detail_image_frame, FALSE, FALSE, 0);

# Öffnen-Button
my $btn_open = Gtk3::Button->new_with_label("Show fullscreen");
$btn_open->get_style_context->add_class('search-btn');
$btn_open->set_border_width(8);
$btn_open->set_sensitive(FALSE);
$detail_box->pack_start($btn_open, FALSE, FALSE, 0);

my $sep_detail = Gtk3::Separator->new('horizontal');
$detail_box->pack_start($sep_detail, FALSE, FALSE, 4);

# Suchfeld für Tag-Filter im Detail
my $detail_filter_box = Gtk3::Box->new('horizontal', 4);
$detail_filter_box->set_border_width(6);
$detail_box->pack_start($detail_filter_box, FALSE, FALSE, 0);

my $lbl_tag_filter = Gtk3::Label->new("Filter tags:");
$lbl_tag_filter->get_style_context->add_class('search-label');
$detail_filter_box->pack_start($lbl_tag_filter, FALSE, FALSE, 0);

my $entry_tag_filter = Gtk3::SearchEntry->new;
$entry_tag_filter->get_style_context->add_class('search-entry');
$entry_tag_filter->set_placeholder_text("e.g. GPS, Date, Camera ...");
$detail_filter_box->pack_start($entry_tag_filter, TRUE, TRUE, 0);

my $chk_selector = Gtk3::CheckButton->new_with_label("exif_selector");
$chk_selector->get_style_context->add_class('search-label');
$chk_selector->set_tooltip_text("Show only tags selected in exif_selector");
$chk_selector->set_active(FALSE);
$detail_filter_box->pack_start($chk_selector, FALSE, FALSE, 4);

# TreeView for EXIF-Tags
my $tag_scroll = Gtk3::ScrolledWindow->new;
$tag_scroll->set_policy('automatic', 'automatic');
$tag_scroll->set_shadow_type('in');
$tag_scroll->set_border_width(6);
$detail_box->pack_start($tag_scroll, TRUE, TRUE, 0);

my $tag_store = Gtk3::ListStore->new('Glib::String', 'Glib::String');
my $tag_filter_model = Gtk3::TreeModelFilter->new($tag_store, undef);
$tag_filter_model->set_visible_func(\&tag_filter_func);

my $tag_tree = Gtk3::TreeView->new_with_model($tag_filter_model);
$tag_tree->get_style_context->add_class('tag-tree');
$tag_tree->set_headers_visible(TRUE);
$tag_tree->set_search_column(0);
$tag_tree->set_rubber_banding(TRUE);

# Columns
my $col_tag = Gtk3::TreeViewColumn->new_with_attributes(
    "Tag",
    Gtk3::CellRendererText->new,
    text => 0
);
$col_tag->set_resizable(TRUE);
$col_tag->set_min_width(120);
$col_tag->set_sort_column_id(0);

my $renderer_val = Gtk3::CellRendererText->new;
$renderer_val->set(ellipsize => 'end');
my $col_val = Gtk3::TreeViewColumn->new_with_attributes(
    "Value",
    $renderer_val,
    text => 1
);
$col_val->set_resizable(TRUE);
$col_val->set_expand(TRUE);

$tag_tree->append_column($col_tag);
$tag_tree->append_column($col_val);
$tag_scroll->add($tag_tree);
log_msg('Tag tree OK');

# right click on Tag → use searchfilter
$tag_tree->signal_connect('button-press-event' => \&on_tag_tree_click);

# ── Status bar ──────────────────────────────────────────────────────────────
my $statusbar = Gtk3::Statusbar->new;
$statusbar->get_style_context->add_class('statusbar');
my $status_ctx = $statusbar->get_context_id('main');
$vbox_main->pack_start($statusbar, FALSE, FALSE, 0);

# ─── Signal-Handler ───────────────────────────────────────────────────────────

# start search
$btn_search->signal_connect(clicked => \&do_search);
$entry_value->signal_connect(activate => \&do_search);
$combo_tag->signal_connect(changed => sub {
    # Auto-Suche wenn Wert schon eingetragen
    do_search() if ($entry_value->get_text // '') ne '';
});

# Reset
$btn_reset->signal_connect(clicked => sub {
    $combo_tag->set_text("Comment");
    $entry_value->set_text('');
    load_all_photos();
});

# Thumbnail-Klick → show detail
$flowbox->signal_connect('child-activated' => \&on_thumb_activated);

# Fullscreen Button
$btn_open->signal_connect(clicked => sub {
    open_fullscreen($selected_photo_id) if $selected_photo_id;
});

# Slider: change thumbnail size
$size_adj->signal_connect('value-changed' => sub {
    $thumb_size = int($size_adj->get_value);
    $lbl_size_val->set_text("${thumb_size}px");
    %thumb_cache = ();
    show_busy("Resizing thumbnails ...");
    if ($search_idle_id) {
        Glib::Source->remove($search_idle_id);
    }
    $search_idle_id = Glib::Timeout->add(300, sub {
        refresh_thumbnails();
        $search_idle_id = undef;
        return FALSE;
    });
});

# Tag filter in detail panel
$entry_tag_filter->signal_connect('search-changed' => sub {
    $tag_filter_model->refilter;
});

$chk_selector->signal_connect(toggled => sub {
    # Grey out the checkbox if no exif_selector config was found
    if ($chk_selector->get_active && !%selected_tags) {
        show_startup_error(
            "No exif_selector config found at:\n$EXIF_SELECTOR_CONF"
        );
        $chk_selector->set_active(FALSE);
        return;
    }
    $tag_filter_model->refilter;
});

$btn_remap->signal_connect(clicked => sub {
    my ($sample) = $dbh->selectrow_array("SELECT path FROM photos LIMIT 1");
    show_remap_dialog($sample // "/unknown/path");
    # Clear thumbnail cache so remapped paths take effect immediately
    %thumb_cache = ();
    render_thumbnails() if @current_results;
});

$btn_first->signal_connect(clicked => sub {
    $current_offset = 0;
    render_thumbnails();
});

$btn_prev->signal_connect(clicked => sub {
    $current_offset -= $PAGE_SIZE;
    $current_offset = 0 if $current_offset < 0;
    render_thumbnails();
});

$btn_next->signal_connect(clicked => sub {
    $current_offset += $PAGE_SIZE;
    render_thumbnails();
});

$btn_last->signal_connect(clicked => sub {
    my $total = scalar @current_results;
    $current_offset = int(($total - 1) / $PAGE_SIZE) * $PAGE_SIZE;
    render_thumbnails();
});
log_msg('All signal handlers connected OK');

# ─── Startup: load config, show window, check path mapping ──────────────────
load_config();
load_exif_selector_config();
log_msg("Calling window->show_all");
$window->show_all;
Gtk3::main_iteration() while Gtk3::events_pending();
log_msg("Checking path mapping...");
check_path_mapping();
log_msg("Path mapping check done");
log_msg("show_all done, calling show_hint");
eval { show_hint("Select an EXIF tag and press Search  -  or click 'Show All'") };
log_msg("show_hint done" . ($@ ? " ERROR: $@" : ""));
my ($n_total) = eval { ($dbh->selectrow_array("SELECT COUNT(*) FROM photos"))[0] } // 0;
log_msg("photo count: $n_total");
eval { status_set("Database: $DB_FILE  |  $n_total photos indexed") };
log_msg("status_set done" . ($@ ? " ERROR: $@" : ""));
log_msg("Entering Gtk3->main");
Gtk3->main;
log_msg("Gtk3->main returned - exiting");


# ── Modal busy dialog with spinner ───────────────────────────────────────────
my $busy_dialog;

sub show_busy {
    my ($message) = @_;
    $message //= "Please wait ...";

    return if $busy_dialog;   # already showing

    $busy_dialog = Gtk3::Window->new('popup');
    $busy_dialog->set_transient_for($window);
    $busy_dialog->set_modal(TRUE);
    $busy_dialog->set_position('center-on-parent');
    $busy_dialog->set_resizable(FALSE);
    $busy_dialog->set_decorated(FALSE);
    $busy_dialog->set_border_width(24);

    my $vbox = Gtk3::Box->new('vertical', 12);
    $busy_dialog->add($vbox);

    my $spin = Gtk3::Spinner->new;
    $spin->set_size_request(48, 48);
    $vbox->pack_start($spin, FALSE, FALSE, 0);

    my $lbl = Gtk3::Label->new($message);
    $lbl->get_style_context->add_class('search-label');
    $vbox->pack_start($lbl, FALSE, FALSE, 0);

    $busy_dialog->show_all;
    $spin->start;

    # Pump events so the dialog is fully painted before caller continues
    Gtk3::main_iteration() while Gtk3::events_pending();
}

sub hide_busy {
    return unless $busy_dialog;
    $busy_dialog->destroy;
    $busy_dialog = undef;
    Gtk3::main_iteration() while Gtk3::events_pending();
}

# ═══════════════════════════════════════════════════════════════════════════════
# SUBROUTINEN
# ═══════════════════════════════════════════════════════════════════════════════

# ── Load exif_selector tag list from ~/.config/exif_selector/config.yaml ────
sub load_exif_selector_config {
    %selected_tags = ();
    unless (-f $EXIF_SELECTOR_CONF) {
        log_msg("exif_selector config not found: $EXIF_SELECTOR_CONF");
        return;
    }
    open my $fh, '<:utf8', $EXIF_SELECTOR_CONF or do {
        log_msg("Cannot read exif_selector config: $!");
        return;
    };
    my $in_tags = 0;
    while (my $line = <$fh>) {
        chomp $line;
        if ($line =~ /^selected_tags\s*:/) {
            $in_tags = 1;
            next;
        }
        if ($in_tags) {
            # List item:  "  - TagName"
            if ($line =~ /^\s+-\s+(.+)$/) {
                $selected_tags{$1} = 1;
            } else {
                # Non-list line means we've left the selected_tags block
                last if $line =~ /^\S/;
            }
        }
    }
    close $fh;
    my $n = scalar keys %selected_tags;
    log_msg("exif_selector: loaded $n selected tags from $EXIF_SELECTOR_CONF");

    # Enable the checkbox now that we have data
    $chk_selector->set_active(TRUE);
}

# ── Translate a DB path to a local path using the stored prefix mapping ───────
sub remap_path {
    my ($path) = @_;
    return $path if $path_prefix_from eq '' || $path_prefix_to eq '';

    # Strip the "from" prefix from the DB path
    my $from = $path_prefix_from;
    $from =~ s|/+$||;          # remove trailing slashes from prefix

    my $relative;
    if ($path =~ /^\Q$from\E\/?(.*)$/) {
        $relative = $1;        # everything after the prefix
    } else {
        return $path;          # prefix not found - return unchanged
    }

    # Join local root with the remaining relative path
    my $to = $path_prefix_to;
    $to =~ s|/+$||;            # remove trailing slash
    return "$to/$relative";
}

# ── Load path mapping from config file ───────────────────────────────────────
sub load_config {
    return unless -f $CONFIG_FILE;
    open my $fh, '<:utf8', $CONFIG_FILE or return;
    while (<$fh>) {
        chomp;
        next if /^\s*#/ || /^\s*$/;
        if (/^path_from=(.*)$/) { $path_prefix_from = $1 }
        if (/^path_to=(.*)$/)   { $path_prefix_to   = $1 }
        if (/^db=(.*)$/)        { }   # reserved for future use
    }
    close $fh;
    log_msg("Config loaded: from='$path_prefix_from' to='$path_prefix_to'");
    # Verify by testing the first path in the DB
    my ($sample) = eval { $dbh->selectrow_array("SELECT path FROM photos LIMIT 1") };
    if ($sample) {
        my $remapped = remap_path($sample);
        log_msg("Sample DB path : $sample");
        log_msg("Remapped to    : $remapped");
        log_msg("File exists    : " . (-f $remapped ? "YES" : "NO"));
    }
}

# ── Save path mapping to config file ─────────────────────────────────────────
sub save_config {
    use File::Path qw(make_path);
    my $dir = "$ENV{HOME}/.config";
    make_path($dir) unless -d $dir;
    open my $fh, '>:utf8', $CONFIG_FILE or do {
        log_msg("Cannot save config: $!");
        return;
    };
    print $fh "# exif_browser configuration\n";
    print $fh "path_from=$path_prefix_from\n";
    print $fh "path_to=$path_prefix_to\n";
    close $fh;
    log_msg("Config saved to $CONFIG_FILE");
}

# ── Detect path mismatch and show remapping dialog if needed ─────────────────
sub check_path_mapping {
    # Sample a few paths from DB
    my $rows = eval {
        $dbh->selectall_arrayref(
            "SELECT path FROM photos ORDER BY RANDOM() LIMIT 20",
            { Slice => {} }
        )
    } or return;

    return unless @$rows;

    # If current mapping already works, we're done
    my $working = 0;
    my $first_local = '';
    for my $row (@$rows) {
        my $local = remap_path($row->{path});
        $first_local ||= $local;
        $working++ if -f $local;
    }
    log_msg("check_path_mapping: $working/" . scalar(@$rows) . " files found locally");
    log_msg("check_path_mapping: first local path tried: $first_local");
    return if $working > 0;   # at least one file found locally -> OK

    # No files found locally -> need to configure mapping
    log_msg("Path mismatch detected - showing remap dialog");

    # Detect common DB prefix from sampled paths
    my $sample_path = $rows->[0]{path};

    show_remap_dialog($sample_path);
}

# ── Path remapping dialog ─────────────────────────────────────────────────────
sub show_remap_dialog {
    my ($sample_db_path) = @_;

    my $dialog = Gtk3::Dialog->new_with_buttons(
        'Photo Path Configuration',
        $window,
        [qw(modal destroy-with-parent)],
        'OK'     => 'ok',
        'Cancel' => 'cancel',
    );
    $dialog->set_default_size(580, 320);
    $dialog->set_border_width(12);

    my $area = $dialog->get_content_area;
    $area->set_spacing(10);
    $area->set_border_width(12);

    # Explanation
    my $lbl_info = Gtk3::Label->new(
        "Photos were indexed on a different machine.\n" .
        "Please map the database path prefix to your local path."
    );
    $lbl_info->set_line_wrap(TRUE);
    $lbl_info->set_xalign(0.0);
    $area->pack_start($lbl_info, FALSE, FALSE, 0);

    # Sample path display
    my $lbl_sample = Gtk3::Label->new("Example path in database:");
    $lbl_sample->set_xalign(0.0);
    $lbl_sample->get_style_context->add_class('search-label');
    $area->pack_start($lbl_sample, FALSE, FALSE, 0);

    my $lbl_path = Gtk3::Label->new($sample_db_path);
    $lbl_path->set_xalign(0.0);
    $lbl_path->set_selectable(TRUE);
    $lbl_path->set_ellipsize('start');
    $area->pack_start($lbl_path, FALSE, FALSE, 0);

    my $sep = Gtk3::Separator->new('horizontal');
    $area->pack_start($sep, FALSE, FALSE, 4);

    # Grid for the two entries
    my $grid = Gtk3::Grid->new;
    $grid->set_column_spacing(10);
    $grid->set_row_spacing(8);
    $area->pack_start($grid, FALSE, FALSE, 0);

    # "From" row
    my $lbl_from = Gtk3::Label->new("Path prefix in database:");
    $lbl_from->set_xalign(0.0);
    $grid->attach($lbl_from, 0, 0, 1, 1);

    my $entry_from = Gtk3::Entry->new;
    $entry_from->set_hexpand(TRUE);
    $entry_from->set_placeholder_text("e.g. /mnt/nas/photos");
    $entry_from->set_text($path_prefix_from || detect_db_prefix($sample_db_path));
    $grid->attach($entry_from, 1, 0, 1, 1);

    # "To" row
    my $lbl_to = Gtk3::Label->new("Local path prefix:");
    $lbl_to->set_xalign(0.0);
    $grid->attach($lbl_to, 0, 1, 1, 1);

    my $entry_to = Gtk3::Entry->new;
    $entry_to->set_hexpand(TRUE);
    $entry_to->set_placeholder_text("e.g. /home/user/photos");
    $entry_to->set_text($path_prefix_to);
    $grid->attach($entry_to, 1, 1, 1, 1);

    # Browse button for local path
    my $btn_browse = Gtk3::Button->new_with_label("Browse ...");
    $btn_browse->signal_connect(clicked => sub {
        my $fc = Gtk3::FileChooserDialog->new(
            'Select local photo folder', $dialog,
            'select-folder',
            'Cancel' => 'cancel',
            'Select' => 'ok',
        );
        $fc->set_current_folder($entry_to->get_text || $ENV{HOME});
        if ($fc->run eq 'ok') {
            $entry_to->set_text($fc->get_filename);
        }
        $fc->destroy;
    });
    $grid->attach($btn_browse, 2, 1, 1, 1);

    # Live status label
    my $lbl_status = Gtk3::Label->new("");
    $lbl_status->set_xalign(0.0);
    $area->pack_start($lbl_status, FALSE, FALSE, 0);

    # Update status when entries change
    my $update_status = sub {
        my $from  = $entry_from->get_text;
        my $to    = $entry_to->get_text;
        return unless $from ne '' && $to ne '';
        (my $test = $sample_db_path) =~ s/^\Q$from\E/$to/;
        if (-f $test) {
            $lbl_status->set_markup("<span foreground='#a6e3a1'>Found: $test</span>");
        } else {
            $lbl_status->set_markup("<span foreground='#f38ba8'>Not found: $test</span>");
        }
    };
    $entry_from->signal_connect('changed' => $update_status);
    $entry_to->signal_connect('changed'   => $update_status);
    $update_status->();   # initial check

    $dialog->show_all;
    my $response = $dialog->run;

    if ($response eq 'ok') {
        $path_prefix_from = $entry_from->get_text;
        $path_prefix_to   = $entry_to->get_text;
        $path_prefix_from =~ s|/+$||;   # strip trailing slash
        $path_prefix_to   =~ s|/+$||;
        save_config();
        log_msg("Path mapping set: '$path_prefix_from' -> '$path_prefix_to'");
    }

    $dialog->destroy;
}

# ── Guess the common directory prefix from a sample path ─────────────────────
sub detect_db_prefix {
    my ($path) = @_;
    # Walk up directory tree and return deepest component that looks like a root
    my @parts = split m{/}, $path;
    # Return up to depth 3 (e.g. /mnt/nas or /home/user/photos)
    my $depth = @parts > 4 ? 3 : 2;
    return join('/', @parts[0..$depth]);
}

# ── Show a centered hint message in the thumbnail area ──────────────────────
sub show_hint {
    my ($text) = @_;
    %widget_data = ();
    for my $child ($flowbox->get_children) {
        $flowbox->remove($child);
    }
    my $lbl = Gtk3::Label->new($text);
    $lbl->get_style_context->add_class('empty-label');
    $lbl->set_line_wrap(TRUE);
    $lbl->set_justify('center');
    my $fbc = Gtk3::FlowBoxChild->new;
    $fbc->add($lbl);
    $flowbox->add($fbc);
    $flowbox->show_all;
}

# ── Load all fotos ──────────────────────────────────────────────────────────
sub load_all_photos {
    show_busy("Loading photos ...");
    status_set("Loading all photos ...");
    Gtk3::main_iteration() while Gtk3::events_pending();

    my $rows = $dbh->selectall_arrayref(
        "SELECT id, path, filename FROM photos ORDER BY filename",
        { Slice => {} }
    );
    @current_results = @$rows;
    $current_offset = 0;
    my $n = scalar @current_results;
    $lbl_results->set_text("$n photo" . ($n == 1 ? '' : 's') . " in database");

    render_thumbnails();

    hide_busy();
    status_set("$n photos loaded  -  Database: $DB_FILE");
}

# ── do search ─────────────────────────────────────────────────────────
sub do_search {
    my $tag   = $combo_tag->get_text // '';
    my $value = $entry_value->get_text      // '';
    $tag   =~ s/^\s+|\s+$//g;
    $value =~ s/^\s+|\s+$//g;

    if ($tag eq '' && $value eq '') {
        load_all_photos();
        return;
    }

    show_busy("Searching ...");
    status_set("Searching ...");
    Gtk3::main_iteration() while Gtk3::events_pending();

    my ($sql, @params);

    if ($tag ne '' && $value ne '') {
        # Tag UND Wert
        $sql = <<'SQL';
SELECT DISTINCT p.id, p.path, p.filename
FROM photos p
JOIN exif_tags t ON p.id = t.photo_id
WHERE t.tag LIKE ? AND t.value LIKE ?
ORDER BY p.filename
SQL
        @params = ("%$tag%", "%$value%");
    } elsif ($tag ne '') {
        # Nur Tag (hat irgendeinen Wert)
        $sql = <<'SQL';
SELECT DISTINCT p.id, p.path, p.filename
FROM photos p
JOIN exif_tags t ON p.id = t.photo_id
WHERE t.tag LIKE ? AND t.value IS NOT NULL
ORDER BY p.filename
SQL
        @params = ("%$tag%");
    } else {
        # Nur Wert (in irgendeinem Tag)
        $sql = <<'SQL';
SELECT DISTINCT p.id, p.path, p.filename
FROM photos p
JOIN exif_tags t ON p.id = t.photo_id
WHERE t.value LIKE ?
ORDER BY p.filename
SQL
        @params = ("%$value%");
    }

    my $rows = eval {
        $dbh->selectall_arrayref($sql, { Slice => {} }, @params);
    };
    if ($@) {
        status_set("Database error: $@");
        hide_busy();
        return;
    }

    @current_results = @$rows;
    $current_offset = 0;
    my $n = scalar @current_results;

    my $search_desc = '';
    $search_desc .= "tag '$tag'"       if $tag   ne '';
    $search_desc .= " and "              if $tag ne '' && $value ne '';
    $search_desc .= "value '$value'"   if $value ne '';

    $lbl_results->set_text("$n result" . ($n == 1 ? "" : "s") . " for: $search_desc");

    render_thumbnails();

    hide_busy();
    status_set("$n results for: $search_desc");
}

# ── render current page of thumbnails ────────────────────────────────────────
sub render_thumbnails {
    show_busy("Rendering thumbnails ...");
    $lbl_results->set_sensitive(FALSE);

    %widget_data = ();
    for my $child ($flowbox->get_children) {
        $flowbox->remove($child);
    }

    unless (@current_results) {
        my $lbl = Gtk3::Label->new("No results");
        $lbl->get_style_context->add_class('empty-label');
        my $fbc = Gtk3::FlowBoxChild->new;
        $fbc->add($lbl);
        $flowbox->add($fbc);
        $flowbox->show_all;
        $btn_first->set_sensitive(FALSE);
        $btn_prev->set_sensitive(FALSE);
        $btn_next->set_sensitive(FALSE);
        $btn_last->set_sensitive(FALSE);
        $lbl_page->set_text("");
        hide_busy();
        $lbl_results->set_sensitive(TRUE);
        return;
    }

    my $total     = scalar @current_results;

    # Clamp offset
    $current_offset = 0                if $current_offset < 0;
    $current_offset = $total - 1       if $current_offset >= $total;
    # Snap to page boundary
    $current_offset = int($current_offset / $PAGE_SIZE) * $PAGE_SIZE;

    my $end        = $current_offset + $PAGE_SIZE - 1;
    $end           = $total - 1 if $end >= $total;
    my $page_num   = int($current_offset / $PAGE_SIZE) + 1;
    my $page_total = int(($total - 1) / $PAGE_SIZE) + 1;

    # Update page label early so user sees progress
    $lbl_page->set_text("loading ...");
    Gtk3::main_iteration() while Gtk3::events_pending();

    for my $row (@current_results[$current_offset .. $end]) {
        my $child = make_thumb_widget($row->{id}, $row->{path}, $row->{filename});
        $flowbox->add($child);
    }
    $flowbox->show_all;

    # Update pagination controls
    $btn_first->set_sensitive($current_offset > 0);
    $btn_prev->set_sensitive($current_offset > 0);
    $btn_next->set_sensitive($end < $total - 1);
    $btn_last->set_sensitive($end < $total - 1);
    $lbl_page->set_text("$page_num / $page_total");

    # Scroll back to top on page change
    my $vadj = $scroll->get_vadjustment;
    $vadj->set_value(0) if $vadj;

    hide_busy();
    $lbl_results->set_sensitive(TRUE);
}

# ── create single thumbnail widget ──────────────────────────────────────
sub make_thumb_widget {
    my ($photo_id, $path, $filename) = @_;

    # Outer Frame (FlowBoxChild)
    my $frame = Gtk3::Box->new('vertical', 2);
    $frame->get_style_context->add_class('thumb-frame');
    $frame->set_size_request($thumb_size + 20, $thumb_size + 36);

    # Foto
    my $image = Gtk3::Image->new;
    $image->set_size_request($thumb_size, $thumb_size);

    my $local_path = remap_path($path);
    my $pixbuf = get_thumbnail($photo_id, $local_path);
    if ($pixbuf) {
        $image->set_from_pixbuf($pixbuf);
    } else {
        # Platzhalterbild
        $image->set_from_icon_name('image-missing', 'dialog');
        $image->set_pixel_size($thumb_size);
    }

    # Label (shortened file name)
    my $short_name = $filename;
    if (length($short_name) > 20) {
        $short_name = substr($short_name, 0, 17) . '...';
    }
    my $lbl = Gtk3::Label->new($short_name);
    $lbl->get_style_context->add_class('thumb-label');
    $lbl->set_tooltip_text($filename);
    $lbl->set_xalign(0.5);

    $frame->pack_start($image, FALSE, FALSE, 0);
    $frame->pack_start($lbl,   FALSE, FALSE, 0);

    # save photo_id/path in global widget hash
    $widget_data{$frame} = { photo_id => $photo_id, photo_path => $path };

    my $fbc = Gtk3::FlowBoxChild->new;
    $fbc->add($frame);
    $fbc->set_tooltip_text($path);
    return $fbc;
}

# ── Thumbnail-Pixbuf load/cache ─────────────────────────────────────────────
sub get_thumbnail {
    my ($photo_id, $path) = @_;
    # path is already remapped by caller

    my $cache_key = "${photo_id}_${thumb_size}";
    return $thumb_cache{$cache_key} if exists $thumb_cache{$cache_key};

    unless (-f $path) {
        $thumb_cache{$cache_key} = undef;
        return undef;
    }

    my $pixbuf = eval {
        GdkPixbuf::Pixbuf->new_from_file_at_scale(
            $path, $thumb_size, $thumb_size, TRUE
        );
    };
    $thumb_cache{$cache_key} = $pixbuf;
    return $pixbuf;
}

# ── rerender thumbnails on resize ─────────────────────────────────
sub refresh_thumbnails {
    render_thumbnails();
}

# ── thumbnail click: Show Details  ─────────────────────────────────────────
sub on_thumb_activated {
    my ($fb, $child) = @_;

    # find photo_id in child widget
    my $frame    = ($child->get_children)[0];
    my $photo_id = $widget_data{$frame}{photo_id};
    my $path     = $widget_data{$frame}{photo_path};

    return unless defined $photo_id;

    # Markierung aktualisieren
    for my $c ($flowbox->get_children) {
        my $f = ($c->get_children)[0];
        $f->get_style_context->remove_class('selected') if $f;
    }
    $frame->get_style_context->add_class('selected');

    show_detail($photo_id, $path);
}

# ── fill detail panel ───────────────────────────────────────────────────────
sub show_detail {
    my ($photo_id, $path) = @_;
    $selected_photo_id = $photo_id;

    my $filename = basename($path);

    # Header aktualisieren
    $lbl_detail_title->set_text($filename);
    $lbl_detail_path->set_text($path);
    $lbl_detail_path->set_tooltip_text($path);

    # Big size preview
    my $local_path = remap_path($path);
    my $big_pixbuf = eval {
        GdkPixbuf::Pixbuf->new_from_file_at_scale($local_path, 360, 220, TRUE);
    };
    if ($big_pixbuf) {
        $detail_image->set_from_pixbuf($big_pixbuf);
    } else {
        $detail_image->set_from_icon_name('image-missing', 'dialog');
        $detail_image->set_pixel_size(64);
    }
    $btn_open->set_sensitive(TRUE);

    # load EXIF tags
    $tag_store->clear;
    my $tags = $dbh->selectall_arrayref(
        "SELECT tag, value FROM exif_tags WHERE photo_id = ? ORDER BY tag",
        { Slice => {} },
        $photo_id
    );

    for my $t (@$tags) {
        my $iter = $tag_store->append;
        $tag_store->set($iter,
            0, $t->{tag}   // '',
            1, $t->{value} // '-',
        );
    }

    my $n_tags = scalar @$tags;
    status_set("$filename  -  $n_tags EXIF tags");
    $entry_tag_filter->set_text('');
}

# ── Tag-Filter in detail treeview ────────────────────────────────────────────
sub tag_filter_func {
    my ($model, $iter) = @_;
    my $tag = $model->get($iter, 0) // '';

    # exif_selector filter: only show tags in the selected_tags list
    if ($chk_selector->get_active && %selected_tags) {
        return FALSE unless exists $selected_tags{$tag};
    }

    # Text filter: substring match on tag name or value
    my $filter = $entry_tag_filter->get_text // '';
    return TRUE if $filter eq '';
    my $val = lc($model->get($iter, 1) // '');
    return index(lc($tag), lc($filter)) >= 0 || index($val, lc($filter)) >= 0;
}

# ── right click on Tag → apply search field ────────────────────────────────
sub on_tag_tree_click {
    my ($widget, $event) = @_;
    return FALSE unless $event->button == 3;  # Rechtsklick

    my ($path_obj) = $widget->get_path_at_pos($event->x, $event->y);
    return FALSE unless $path_obj;

    my $iter  = $tag_filter_model->get_iter($path_obj);
    return FALSE unless $iter;

    my $tag = $tag_filter_model->get($iter, 0);
    my $val = $tag_filter_model->get($iter, 1);

    my $menu = Gtk3::Menu->new;

    my $item1 = Gtk3::MenuItem->new_with_label("Search by tag: $tag");
    $item1->signal_connect(activate => sub {
        $combo_tag->set_text($tag);
        $entry_value->set_text('');
        do_search();
    });
    $menu->append($item1);

    if (defined $val && $val ne '-') {
        my $short_val = length($val) > 30 ? substr($val,0,30).'...' : $val;
        my $item2 = Gtk3::MenuItem->new_with_label("Search for value: $short_val");
        $item2->signal_connect(activate => sub {
            $combo_tag->set_text($tag);
            $entry_value->set_text($val);
            do_search();
        });
        $menu->append($item2);
    }

    $menu->show_all;
    $menu->popup_at_pointer($event);
    return TRUE;
}

# ── Fullscreen Window ──────────────────────────────────────────────────────────
sub open_fullscreen {
    my ($photo_id) = @_;
    return unless defined $photo_id;

    my ($path) = $dbh->selectrow_array(
        "SELECT path FROM photos WHERE id = ?", undef, $photo_id
    );
    $path = remap_path($path);
    return unless $path && -f $path;

    my $win = Gtk3::Window->new('toplevel');
    $win->set_title(basename($path) . "  -  Vollbild");
    $win->set_default_size(900, 700);
    $win->set_transient_for($window);
    $win->set_position('center-on-parent');

    my $vb = Gtk3::Box->new('vertical', 0);
    $win->add($vb);

    my $scroll2 = Gtk3::ScrolledWindow->new;
    $scroll2->set_policy('automatic', 'automatic');
    $vb->pack_start($scroll2, TRUE, TRUE, 0);

    my $img = Gtk3::Image->new;

    # Pixbuf laden (max 1200×900)
    my $pb = eval {
        GdkPixbuf::Pixbuf->new_from_file_at_scale($path, 1200, 900, TRUE);
    };
    if ($pb) {
        $img->set_from_pixbuf($pb);
    } else {
        $img->set_from_icon_name('image-missing', 'dialog');
        $img->set_pixel_size(128);
    }

    $scroll2->add_with_viewport($img);

    my $btn_close = Gtk3::Button->new_with_label("Close");
    $btn_close->get_style_context->add_class('reset-btn');
    $btn_close->signal_connect(clicked => sub { $win->destroy });
    $vb->pack_start($btn_close, FALSE, FALSE, 4);

    $win->signal_connect('key-press-event' => sub {
        my (undef, $ev) = @_;
        $win->destroy if $ev->keyval == Gtk3::Gdk::KEY_Escape();
        return FALSE;
    });

    $win->show_all;
}

# ── fill tag ComboBox ─────────────────────────────────────────────────────


# ── Status bar ─────────────────────────────────────────────────────────────
sub status_set {
    my ($msg) = @_;
    $statusbar->pop($status_ctx);
    $statusbar->push($status_ctx, $msg);
}

# ── startup error dialog ────────────────────────────────────────────────────────
sub show_startup_error {
    my ($msg) = @_;
    my $dlg = Gtk3::MessageDialog->new(
        undef, 'modal', 'error', 'ok', $msg
    );
    $dlg->set_title("$APP_TITLE  -  Error");
    $dlg->run;
    $dlg->destroy;
}
